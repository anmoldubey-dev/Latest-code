    { "name": "french-ai",     "priority": 75,  "enabled": true, "conditions": { "lang": ["fr"]    }, "target": { "queue_name": "ai-french",     "ai_config": { "lang": "fr",    "voice": "Sophie (Clear Female)",     "llm": "ollama" }, "fallback_action": "ai_bot" } },
    { "name": "german-ai",     "priority": 80,  "enabled": true, "conditions": { "lang": ["de"]    }, "target": { "queue_name": "ai-german",     "ai_config": { "lang": "de",    "voice": "Lena (Bright Female)",      "llm": "ollama" }, "fallback_action": "ai_bot" } },
