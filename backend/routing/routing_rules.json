    { "name": "default-fallback", "priority": 999, "enabled": true, "conditions": {},               "target": { "queue_name": "ai-default",    "ai_config": { "lang": "en",    "voice": "Emma (Warm Female)",        "llm": "ollama" }, "fallback_action": "ai_bot" } }
