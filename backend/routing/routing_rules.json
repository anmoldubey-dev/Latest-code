{
  "version": "1.1",
  "description": "AI call routing rules — maps lang to AI voice + LLM",
  "rules": [
    { "name": "hindi-ai",      "priority": 10,  "enabled": true, "conditions": { "lang": ["hi"]    }, "target": { "queue_name": "ai-hindi",      "ai_config": { "lang": "hi",    "voice": "Divya (Warm Female)",      "llm": "ollama" }, "fallback_action": "ai_bot" } },
    { "name": "english-in-ai", "priority": 20,  "enabled": true, "conditions": { "lang": ["en-in"] }, "target": { "queue_name": "ai-en-in",      "ai_config": { "lang": "en-in", "voice": "Aditi (Clear Female)",      "llm": "ollama" }, "fallback_action": "ai_bot" } },
