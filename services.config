# ================================================================
#  Voice AI Core — Service Launch Config
#  Used by start_all.bat to decide which services to start.
#
#  Set a service to false to skip it on next start_all.bat run.
#  Lines starting with # are comments and are ignored.
# ================================================================

LIVEKIT=true
DIARIZATION=true
TRANSLATOR=true
TTS_GLOBAL=true
TTS_INDIC=true
VOICE_CLONER=true
BACKEND=true
