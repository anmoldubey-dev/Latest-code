# ================================================================
#  Voice AI Core — Service Launch Config
#  Used by start_all.bat to decide which services to start.
#
#  Set a service to false to skip it on next start_all.bat run.
#  Lines starting with # are comments and are ignored.
# ================================================================

# ── STT model ──────────────────────────────────────────────────
#  Options: tiny, base, small, medium, large-v2, large-v3, turbo
#  large-v3 = best accuracy  |  small = fastest on CPU
WHISPER_MODEL=small

LIVEKIT=false
DIARIZATION=false
HAUP_RAG=true

# ── HAUP RAG Tables ────────────────────────────────────────────
#  Comma-separated — RAG searches ONLY these tables.
#  Available tables:
#    users              — 50 customer records (name, email, phone, country)
#    conversation_turns — 16 past call transcripts with embeddings (role, text, lang)
#    agents             — agent profiles
#    vector_store       — HAUP vector store (always included automatically)
#
#  Examples:
#    RAG_TABLES=users                         = only customer lookup
#    RAG_TABLES=conversation_turns            = only past transcripts
#    RAG_TABLES=users,conversation_turns      = both (recommended)
RAG_TABLES=users,conversation_turns

# ── Smart RAG (inline call pipeline) ───────────────────────────
#  SMART_RAG=true  = RAG runs BEFORE every LLM response in live calls
#  Set false for pure LLM responses with no RAG context.
#  SMART_RAG_TABLES = tables to search during live calls (separate from HAUP RAG)
#    Use vector_store for knowledge base docs only (recommended)
SMART_RAG=true
SMART_RAG_TABLES=conversation_turns

TRANSLATOR=false
TTS_GLOBAL=false
TTS_INDIC=true
VOICE_CLONER=false
OLLAMA=true
AVATAR_SUMMARY_AI=gemini
BACKEND=true

# ── Backend mode ───────────────────────────────────────────────
#  web  =  app.py  (FastAPI + WebSocket + browser call UI on :8000)
#  cli  =  main.py (real-time mic -- STT -- LLM -- TTS -- speakers,
#                   no HTTP server, no browser needed)
BACKEND_MODE=web

# ── Admin Console ──────────────────────────────────────────────
#  React dashboard on :5173  (requires Node.js + npm install)
#  The call UI at :8000 works WITHOUT this — this is the 14-page
#  admin panel only (monitoring, voice lab, memory explorer, etc.)
ADMIN_CONSOLE=true
