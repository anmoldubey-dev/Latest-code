# PostgreSQL (Neon) Connection
NEON_CONNECTION_STRING=postgresql://user:password@host.neon.tech/dbname

# pgvector Connection (use direct connection, not pooler, for LISTEN/NOTIFY)
PGVECTOR_CONNECTION_STRING=postgresql://user:password@host.neon.tech/dbname
PGVECTOR_TABLE=vector_store

# Hardware Configuration
DEVICE=cpu  # Options: cpu, cuda (for GPU)

# Embedding Model
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Vector Index Configuration (HAUP v3.0 uses HNSW with cosine distance)
# HNSW Parameters:
#   - m: Number of connections per layer (default: 16)
#     Higher = better accuracy, more memory (16-32 recommended)
#   - ef_construction: Build quality (default: 64)
#     Higher = better accuracy, slower build (64-200 recommended)
# Distance Metric: Cosine distance (measures angle between vectors)
VECTOR_INDEX_TYPE=hnsw  # Options: hnsw (default), ivfflat
HNSW_M=16
HNSW_EF_CONSTRUCTION=64

# LLM Configuration (for RAG)
OPENAI_API_KEY=your_openai_api_key_here
LLM_MODEL=gpt-4

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# Optional: Neo4j Graph Features (disabled by default)
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=your_password
